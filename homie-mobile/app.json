{
  "expo": {
    "name": "Homie",
    "slug": "homie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "homie",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3B8D8C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.homie.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#3B8D8C",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.homie.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      "expo-secure-store",
      "expo-location",
      "expo-image-picker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1de08d30-8cc5-458b-9d79-7eebefb0c8fb"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1de08d30-8cc5-458b-9d79-7eebefb0c8fb"
    }
  }
}
